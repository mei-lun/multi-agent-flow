# Server
MAF_DATA_DIR=./data
MAF_DATABASE_PATH=./data/maf.db
MAF_CHECKPOINT_DATABASE_PATH=./data/checkpoints.db
MAF_ARTIFACT_DIR=./data/artifacts
MAF_LOG_LEVEL=INFO

# Runner
MAF_SERVER_URL=http://127.0.0.1:8000
MAF_RUNNER_NAME=local-runner
MAF_RUNNER_WORKSPACE_DIR=./data/workspaces
MAF_RUNNER_CAPACITY=1

# Secrets are intentionally omitted. Store them through the application UI/keyring.

