# =============================================================================
# Multi-Agent Flow environment variables
# =============================================================================
# Copy this file to ``.env`` and fill in the values. Secrets must never be
# committed to Git. User model API keys are stored through the SecretStore
# (OS keyring or AES-GCM fallback), not as plain environment variables.
#
# The runner does NOT self-host an HTTP control-plane endpoint and does NOT
# call the central server over HTTP for coordination. Control flows through
# Git pull/push on ``maf/control`` (see the Git coordination protocol).
# =============================================================================


# -----------------------------------------------------------------------------
# Server (apps/server)
# -----------------------------------------------------------------------------

# Deployment environment (dev/staging/prod).
MAF_ENV=dev

# Single-organization boundary ID (required).
MAF_ORGANIZATION_ID=org-0001

# Central data directory; relative data sub-paths below are confined here to
# prevent path traversal. Use an absolute path in production.
MAF_DATA_DIR=./data

# Business SQLite database path (relative to MAF_DATA_DIR).
MAF_DATABASE_PATH=maf.db

# LangGraph checkpoint SQLite path (relative to MAF_DATA_DIR).
MAF_CHECKPOINT_DATABASE_PATH=checkpoints.db

# Artifact store root directory (relative to MAF_DATA_DIR).
MAF_ARTIFACT_ROOT=artifacts

# Server-side workspace root directory (relative to MAF_DATA_DIR).
MAF_WORKSPACE_ROOT=workspaces

# Local Git working tree root used for coordination commits (required).
MAF_GIT_REPO_ROOT=./repo

# Git coordination control branch; the server is the single writer.
MAF_CONTROL_BRANCH=maf/control

# Default Git remote URL for the server's coordination repository (optional).
# Used by RepositoryGateway.verify_binding as the default remote when no
# per-binding remote_url is registered. Can be a named remote ("origin") or
# a full URL ("https://github.com/org/repo.git").
# MAF_GIT_REMOTE_URL=origin

# Path to an SSH private key for server-side Git operations (optional).
# Used by RepositoryGateway.verify_binding when a binding's credential_type
# is SSH_KEY. Must be an absolute path to an existing file; the file must be
# readable by the server process. Prefer SSH agent over static key files.
# MAF_GIT_SSH_KEY_PATH=

# FastAPI listen host and port.
MAF_SERVER_HOST=127.0.0.1
MAF_SERVER_PORT=8000

# External base URL for API/SSE endpoints (required).
MAF_PUBLIC_BASE_URL=http://127.0.0.1:8000

# Logging.
MAF_LOG_LEVEL=INFO
# MAF_LOG_FILE=./data/logs/server.log

# Path to the master key file for SecretStore AES-GCM fallback (optional).
# MAF_MASTER_KEY_FILE=./data/keys/master.key

# Path to the capability token signing key file (optional).
# MAF_CAPABILITY_SIGNING_KEY_FILE=./data/keys/capability_signing.key

# Bootstrap secret for session/JWT signing (SecretStr, required).
# Generate a long random string; never log or expose this value.
MAF_SECRET_KEY=change-me-to-a-long-random-string


# -----------------------------------------------------------------------------
# Runner (apps/runner)
# -----------------------------------------------------------------------------
# The runner coordinates through Git only: it fetches ``maf/control``,
# appends events to ``maf/node/<node-id>`` and pushes task branches.
# There is no runner HTTP port and no runner-to-server control API.

# Deployment environment (dev/staging/prod).
# MAF_ENV=dev

# Persistent node identifier, format ``node-<uuid>`` (required).
MAF_RUNNER_ID=node-00000000-0000-0000-0000-000000000001

# Capability labels for task matching (comma-separated).
MAF_RUNNER_LABELS=python,docker

# Maximum concurrent assignments the node accepts.
MAF_RUNNER_MAX_CONCURRENCY=1

# Git remote URL for fetching ``maf/control`` (required).
MAF_CONTROL_REMOTE_URL=origin

# Git coordination control branch name.
# MAF_CONTROL_BRANCH=maf/control

# Root directory for task workspaces and local data (required).
MAF_WORKSPACE_ROOT=./data/workspaces

# Path to the local model alias mapping file (required).
MAF_MODEL_MAPPING_PATH=./config/model-mapping.yaml

# Path to the capability token cache (relative to MAF_WORKSPACE_ROOT).
MAF_CAPABILITY_TOKEN_CACHE_PATH=capability-tokens.db

# Allowed Git working tree roots for task repos (comma-separated).
MAF_LOCAL_GIT_ROOTS=./data/repos

# Whitelist of Docker image references for task containers (comma-separated).
MAF_ALLOWED_DOCKER_IMAGES=python:3.11-slim,node:20-slim

# Seconds between control fetch polls.
MAF_POLL_INTERVAL_SECONDS=30

# Maximum seconds between progress events (protocol §8: 15 minutes).
MAF_PROGRESS_INTERVAL_SECONDS=900

# Logging.
# MAF_LOG_LEVEL=INFO
# MAF_LOG_FILE=./data/logs/runner.log

# Optional Git credentials token for the control remote (SecretStr).
# Used for HTTPS remotes; the runner injects it into the subprocess env as
# MAF_GIT_CREDENTIAL_TOKEN (singular) for the askpass helper to read.
# Prefer SSH keys or credential helpers over plain tokens in production.
# MAF_GIT_CREDENTIALS_TOKEN=

# Path to an SSH private key for runner-side Git operations (optional).
# When set, the runner uses SSH (GIT_SSH_COMMAND=ssh -i <path>) instead of
# an HTTPS token for fetching control and pushing task branches. Must be an
# absolute path to an existing file readable by the runner process.
# Prefer SSH agent over static key files in production.
# MAF_GIT_SSH_KEY_PATH=

# Path to the capability token signing key file (optional).
# MAF_CAPABILITY_SIGNING_KEY_FILE=./data/keys/capability_signing.key
